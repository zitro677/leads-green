# ============================================
# Green Landscape Irrigation — AI Lead Engine
# Copy to .env and fill in your values
# ============================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=sk-...

# VAPI (voicebot)
VAPI_API_KEY=your-vapi-key
VAPI_ASSISTANT_ID=your-assistant-id
VAPI_PHONE_NUMBER_ID=your-phone-number-id

# Calendly
CALENDLY_API_KEY=your-calendly-key

# NumLookup (reverse address → phone enrichment)
# Free tier: 500 lookups/month — https://www.numlookupapi.com/
NUMLOOKUP_API_KEY=your-numlookup-key

# SerpAPI (Google scraping)
SERPAPI_KEY=your-serpapi-key

# Apify (social scraping)
APIFY_TOKEN=your-apify-token

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Email outreach (Gmail SMTP — free)
# Setup: myaccount.google.com → Security → App Passwords
EMAIL_FROM=your@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM_NAME=Green Landscape Irrigation
# Optional: override SMTP provider (defaults to Gmail)
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587

# SMS outreach (Twilio — ~$0.008/SMS)
# Setup: twilio.com → Console → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+18135550000

# App settings
APP_ENV=development
LOG_LEVEL=INFO
SCORE_CALL_THRESHOLD=55
SCORE_REVIEW_THRESHOLD=20
MAX_CALL_ATTEMPTS=3
